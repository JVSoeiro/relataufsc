NODE_ENV=production
APP_URL=http://localhost:5000
APP_NAME=RelataUFSC
DATA_DIR=/app/data
POSTGRES_URL=postgres://postgres:password@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
MOCK_MODE=false
NEXT_PUBLIC_MOCK_MODE=false
UPLOAD_PENDING_DIR=/app/data/uploads/pending
UPLOAD_PUBLIC_DIR=/app/data/uploads/public
MAX_UPLOAD_SIZE_MB=25
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MODERATION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
MODERATION_TOKEN_TTL_MINUTES=720
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=
BREVO_SMTP_SECURE=false
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=RelataUFSC
SEED_DEMO_DATA=false
SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=300
SUBMISSION_RATE_LIMIT_MAX_ATTEMPTS=4
PORT=5000
